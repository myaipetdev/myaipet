{
  "manifest_version": 3,
  "name": "MY AI PET — Desktop Companion",
  "version": "2.2.3",
  "description": "Your AI pet lives in your browser — walks around every site, reads the page you're on and explains it in its own voice, talks to you, evolves, plays mini-games, and collects Play Points.",
  "permissions": ["storage", "alarms", "notifications"],
  "host_permissions": [
    "https://app.myaipet.ai/*",
    "https://myaipet.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": [
        "*://*.paypal.com/*",
        "*://accounts.google.com/*",
        "*://mail.google.com/*",
        "*://outlook.live.com/*",
        "*://outlook.office.com/*",
        "*://*.icloud.com/*",
        "*://*.atlassian.net/*",
        "*://*.1password.com/*",
        "*://*.lastpass.com/*",
        "*://*.bitwarden.com/*",
        "*://*.chase.com/*",
        "*://*.bankofamerica.com/*",
        "*://*.wellsfargo.com/*",
        "*://*.citi.com/*",
        "*://*.citibank.com/*",
        "*://*.capitalone.com/*",
        "*://*.usbank.com/*",
        "*://*.americanexpress.com/*",
        "*://*.discover.com/*",
        "*://*.fidelity.com/*",
        "*://*.schwab.com/*",
        "*://*.vanguard.com/*",
        "*://*.robinhood.com/*",
        "*://*.coinbase.com/*",
        "*://*.binance.com/*",
        "*://*.kraken.com/*",
        "*://*.upbit.com/*",
        "*://*.bithumb.com/*",
        "*://*.kbstar.com/*",
        "*://*.shinhan.com/*",
        "*://*.shinhancard.com/*",
        "*://*.wooribank.com/*",
        "*://*.kebhana.com/*",
        "*://*.hanabank.com/*",
        "*://*.nonghyup.com/*",
        "*://*.kakaobank.com/*",
        "*://*.tossbank.com/*",
        "*://*.ibk.co.kr/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
