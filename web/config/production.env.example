# Copy reviewed values into the host-managed .env.production file. This
# committed template intentionally contains no credentials or usable URLs.

DATABASE_URL=
STORAGE_PROVIDER=local
AWS_S3_BUCKET=
AWS_S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

OPENAI_API_KEY=
GROK_API_KEY=
FAL_API_KEY=
JWT_SECRET=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
AGENT_ENCRYPTION_KEY=
CRON_SECRET=
NEXT_PUBLIC_APP_URL=https://app.myaipet.ai

# Launch kill-switches. Keep these literal single assignments until the
# corresponding production checklist and smoke gates explicitly change.
PAYMENTS_ENABLED=false
PAYMENT_MIN_CONFIRMATIONS=3
OAUTH_CONNECTIONS_ENABLED=false
AGENT_CHANNELS_ENABLED=false
PET_LORA_ENABLED=false
BLOCKCHAIN_ENABLED=false
REFERRALS_ENABLED=false

# Optional, disabled unless deliberately enabled after cost review.
PETCLAW_BEST_OF_N=false
