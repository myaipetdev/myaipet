generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               Int              @id @default(autoincrement())
  wallet_address   String           @unique @db.VarChar(42)
  nonce            String           @db.VarChar(32)
  credits          Int              @default(0)
  pet_slots        Int              @default(1)
  airdrop_points   Int              @default(0)
  created_at       DateTime         @default(now())
  updated_at       DateTime         @default(now()) @updatedAt
  generations      Generation[]
  credit_purchases CreditPurchase[]
  pets             Pet[]
  interactions     PetInteraction[]
  likes            Like[]
  comments         Comment[]
  followers        Follow[]         @relation("following")
  following        Follow[]         @relation("follower")
  profile          UserProfile?
  last_active_at   DateTime         @default(now())
  successor_wallet String?          @db.VarChar(42)
  // Mission system (Phase 1)
  daily_missions    DailyMission[]
  user_streak       UserStreak?
  streak_purchases  StreakPurchase[]
  // Mission system (Phase 2 + 3)
  periodic_missions PeriodicMission[]
  buddy_as_a        StreakBuddy[]     @relation("StreakBuddyA")
  buddy_as_b        StreakBuddy[]     @relation("StreakBuddyB")
  sos_sent          StreakSos[]       @relation("SosSender")
  sos_helped        StreakSos[]       @relation("SosHelper")
  pet_dates         PetDate[]
  subscription      UserSubscription?

  @@map("users")
}

model Generation {
  id              Int                @id @default(autoincrement())
  user_id         Int?
  pet_type        Int
  style           Int
  prompt          String?            @db.Text
  duration        Int
  photo_path      String             @db.VarChar(512)
  video_path      String?            @db.VarChar(512)
  content_hash    String?            @db.VarChar(66)
  tx_hash         String?            @db.VarChar(66)
  chain           String?            @db.VarChar(10)
  status          String             @default("pending") @db.VarChar(20)
  error_message   String?            @db.Text
  fal_request_id  String?            @db.VarChar(128)
  credits_charged Int
  created_at      DateTime           @default(now())
  completed_at    DateTime?
  user            User?              @relation(fields: [user_id], references: [id])
  likes           Like[]
  comments        Comment[]
  agent_reactions PetAgentReaction[]

  @@index([user_id])
  @@map("generations")
}

model Transaction {
  id           Int      @id @default(autoincrement())
  user_id      Int?
  type         String   @db.VarChar(20)
  tx_hash      String   @db.VarChar(66)
  chain        String   @db.VarChar(10)
  block_number Int?
  gas_used     Int?
  created_at   DateTime @default(now())

  @@index([user_id])
  @@index([tx_hash])
  @@map("transactions")
}

model CreditPurchase {
  id                Int      @id @default(autoincrement())
  user_id           Int
  credits           Int
  amount_usd        Float
  // audit H14: UNIQUE makes on-chain payment replay impossible at the DB level
  // (the route's findFirst check was a TOCTOU race without this).
  payment_tx_hash   String?  @unique @db.VarChar(66)
  recording_tx_hash String?  @db.VarChar(66)
  chain             String?  @db.VarChar(10)
  status            String   @default("pending") @db.VarChar(20)
  created_at        DateTime @default(now())
  user              User     @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@map("credit_purchases")
}

// audit C3: single global ledger of consumed on-chain payments. EVERY paid
// endpoint (credits, subscription, action, premium shop) records the tx_hash
// here inside its grant transaction, so one payment can never be redeemed
// across multiple features. The UNIQUE constraint is the authoritative guard.
model ConsumedPayment {
  id         Int      @id @default(autoincrement())
  tx_hash    String   @unique @db.VarChar(66)
  user_id    Int
  purpose    String   @db.VarChar(40) // "credits" | "subscription" | "action" | "shop_premium"
  amount_usd Float
  created_at DateTime @default(now())

  @@index([user_id])
  @@map("consumed_payments")
}

model Pet {
  id                    Int                     @id @default(autoincrement())
  user_id               Int
  name                  String                  @db.VarChar(50)
  species               Int
  personality_type      String                  @default("friendly") @db.VarChar(20)
  level                 Int                     @default(1)
  experience            Int                     @default(0)
  happiness             Int                     @default(70)
  energy                Int                     @default(100)
  hunger                Int                     @default(30)
  bond_level            Int                     @default(0)
  total_interactions    Int                     @default(0)
  avatar_url            String?                 @db.Text
  appearance_desc       String?                 @db.Text
  is_active             Boolean                 @default(true)
  soul_version          Int                     @default(1)
  personality_modifiers Json?                   @default("{}")
  last_dream_at         DateTime?
  last_interaction_at   DateTime?
  created_at            DateTime                @default(now())
  updated_at            DateTime                @default(now()) @updatedAt
  element               String                  @default("normal") @db.VarChar(10)
  evolution_stage       Int                     @default(0)
  evolution_name        String?                 @db.VarChar(30)
  // Combat stats — upgradeable via paid /api/pets/[petId]/stats/upgrade.
  // Used by Pet Battle League ranking + matchmaking. Combined power = atk+def+spd.
  atk                   Int                     @default(10)
  def                   Int                     @default(10)
  spd                   Int                     @default(10)
  care_streak           Int                     @default(0) // consecutive days of care
  last_care_at          DateTime?
  user                  User                    @relation(fields: [user_id], references: [id])
  memories              PetMemory[]
  interactions          PetInteraction[]
  dream_journals        DreamJournal[]
  insights              PetInsight[]
  loras                 PetLora[]
  notifications         PetNotification[]
  autonomous_actions    PetAutonomousAction[]
  soul_exports          SoulExport[]
  skills                PetSkill[]
  equipped_items        PetEquippedItem[]
  agent_reactions       PetAgentReaction[]
  agent_likes           Like[]
  agent_comments        Comment[]
  platform_connections  PetPlatformConnection[]
  agent_messages        PetAgentMessage[]
  agent_schedule        PetAgentSchedule?
  conversations         PetConversation[]
  persona               PetPersona?
  soul_nft              PetSoulNft?
  memory_nfts           MemoryNft[]
  inheritance_events    InheritanceEvent[]

  @@index([user_id])
  @@map("pets")
}

model PetMemory {
  id            Int      @id @default(autoincrement())
  pet_id        Int
  memory_type   String   @db.VarChar(20)
  content       String   @db.Text
  emotion       String   @default("calm") @db.VarChar(20)
  importance    Int      @default(1)
  is_minted     Boolean  @default(false)
  memory_nft_id Int?
  // Optional embedding vector stored as a plain JSON float array (no pgvector —
  // per-pet retrieval is candidate-limited to ~400 rows, so app-side cosine is
  // exact + fast at this scale). Null until an owner connects an embedding key
  // and the backfill (scripts/embed-memories.mjs) or write path populates it.
  embedding     Json?
  created_at    DateTime @default(now())
  pet           Pet      @relation(fields: [pet_id], references: [id])

  @@index([pet_id])
  @@map("pet_memories")
}

model PetInteraction {
  id                Int      @id @default(autoincrement())
  pet_id            Int
  user_id           Int
  interaction_type  String   @db.VarChar(20)
  response_text     String?  @db.Text
  happiness_change  Int      @default(0)
  energy_change     Int      @default(0)
  hunger_change     Int      @default(0)
  experience_gained Int      @default(0)
  created_at        DateTime @default(now())
  pet               Pet      @relation(fields: [pet_id], references: [id])
  user              User     @relation(fields: [user_id], references: [id])

  @@index([pet_id])
  @@index([user_id])
  @@map("pet_interactions")
}

model DreamJournal {
  id                  Int      @id @default(autoincrement())
  pet_id              Int
  dream_date          DateTime @db.Date
  summary             String   @db.Text
  emotional_tone      String   @db.VarChar(30)
  personality_changes Json?
  stat_changes        Json?
  significant_events  Json?
  created_at          DateTime @default(now())
  pet                 Pet      @relation(fields: [pet_id], references: [id])

  @@index([pet_id])
  @@map("dream_journals")
}

// Pet Daydream insights — caring observations the pet synthesizes by
// connecting two memories about the owner (see lib/petclaw/memory/daydream.ts).
// Surfaced proactively on My Pet so the pet feels like it thinks about you.
model PetInsight {
  id           Int      @id @default(autoincrement())
  pet_id       Int
  insight      String   @db.Text          // the caring observation, 1st person
  rationale    String?  @db.Text          // why the pet connected these memories
  mood         String   @db.VarChar(20)   // tender | playful | concerned | hopeful
  score        Int      @default(5)       // critic score 0-10
  source_keys  Json?                       // memory keys that fed it
  seen         Boolean  @default(false)   // has the owner viewed it
  reacted      Boolean  @default(false)   // did the owner react (kept for feedback)
  // Set when the daydream-to-video cron turns this insight into an auto-generated
  // video (generations.id) — doubles as the "already converted" marker.
  video_generation_id Int?
  created_at   DateTime @default(now())
  pet          Pet      @relation(fields: [pet_id], references: [id], onDelete: Cascade)

  @@index([pet_id, created_at])
  @@map("pet_insights")
}

// Per-pet LoRA fine-tune checkpoint (fal.ai flux-lora-fast-training). One
// "ready" row per pet is the active identity model used for image generation.
model PetLora {
  id             Int       @id @default(autoincrement())
  pet_id         Int
  status         String    @default("training") @db.VarChar(20) // training | ready | failed
  fal_request_id String?   @db.VarChar(128)
  lora_url       String?   @db.VarChar(512)   // diffusers safetensors URL once ready
  trigger_word   String    @db.VarChar(40)    // rare token bound to this pet's identity
  images_used    Json?                        // training image URLs (provenance)
  error_message  String?   @db.Text
  created_at     DateTime  @default(now())
  completed_at   DateTime?
  pet            Pet       @relation(fields: [pet_id], references: [id], onDelete: Cascade)

  @@index([pet_id, created_at])
  @@map("pet_loras")
}

// BYO model connections (FEATURE 1). Owner-scoped; the API key is encrypted at
// rest via src/lib/crypto.ts. The LLM router (src/lib/llm/router.ts) prefers a
// connection whose task_scopes include the call's task, else falls back to the
// platform Grok default. Additive table — safe migration.
model ModelConnection {
  id            Int      @id @default(autoincrement())
  owner_user_id Int
  provider      String   @db.VarChar(20)
  label         String   @db.VarChar(60)
  model         String   @db.VarChar(80)
  encrypted_key String   @db.Text
  task_scopes   String[]
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now()) @updatedAt

  @@index([owner_user_id])
  @@map("model_connections")
}

// CLI personal access tokens. Minted from the web app ("Generate CLI token"),
// these are long-lived, revocable, owner-bound credentials the CLI/SDK use
// instead of pasting the short-lived (8h, nonce-bound) web JWT. Only the
// sha256 hash is stored — the plaintext is shown once at mint time. Auth path:
// lib/auth.ts getUser() resolves a `pck_`-prefixed Bearer token here.
model CliToken {
  id            Int       @id @default(autoincrement())
  owner_user_id Int
  token_hash    String    @unique @db.VarChar(64)
  prefix        String    @db.VarChar(16)
  label         String    @db.VarChar(60)
  created_at    DateTime  @default(now())
  last_used_at  DateTime?
  revoked_at    DateTime?
  expires_at    DateTime?

  @@index([owner_user_id])
  @@map("cli_tokens")
}

// Cat Catch — collectible street cats caught via the live camera. A caught cat
// is a lightweight creature (NOT a full Pet): real capture photo + game stats
// rolled at catch time by rarity. lat/lng power the nearby-catches map.
model CaughtCat {
  id            Int      @id @default(autoincrement())
  owner_user_id Int
  kind          String   @default("cat") @db.VarChar(8) // cat | dog
  name          String   @db.VarChar(40)
  breed         String   @db.VarChar(40)
  rarity        String   @db.VarChar(12) // gray | green | blue | purple | orange
  element       String   @db.VarChar(10)
  hp            Int
  atk           Int
  def           Int
  spd           Int
  level         Int      @default(1)
  photo_path    String   @db.Text
  lat           Float?
  lng           Float?
  caught_at     DateTime @default(now())

  @@index([owner_user_id])
  @@index([lat, lng])
  @@map("caught_cats")
}

model PetNotification {
  id                Int      @id @default(autoincrement())
  pet_id            Int
  notification_type String   @db.VarChar(20)
  message           String   @db.Text
  is_read           Boolean  @default(false)
  created_at        DateTime @default(now())
  pet               Pet      @relation(fields: [pet_id], references: [id])

  @@index([pet_id])
  @@map("pet_notifications")
}

model PetAutonomousAction {
  id            Int      @id @default(autoincrement())
  pet_id        Int
  urge_type     String   @db.VarChar(20)
  action_taken  String   @db.VarChar(100)
  prompt_used   String?  @db.Text
  generation_id Int?
  credits_used  Int      @default(0)
  platform      String?  @db.VarChar(20)
  result        Json?
  created_at    DateTime @default(now())
  pet           Pet      @relation(fields: [pet_id], references: [id])

  @@index([pet_id])
  @@map("pet_autonomous_actions")
}

model SoulExport {
  id          Int      @id @default(autoincrement())
  pet_id      Int
  ipfs_cid    String   @db.VarChar(128)
  soul_hash   String   @db.VarChar(64)
  tx_hash     String?  @db.VarChar(66)
  chain       String   @default("base") @db.VarChar(10)
  version     Int      @default(1)
  exported_at DateTime @default(now())
  pet         Pet      @relation(fields: [pet_id], references: [id])

  @@index([pet_id])
  @@map("soul_exports")
}

model Like {
  id            Int        @id @default(autoincrement())
  user_id       Int
  generation_id Int
  pet_id        Int?
  created_at    DateTime   @default(now())
  user          User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  generation    Generation @relation(fields: [generation_id], references: [id], onDelete: Cascade)
  pet           Pet?       @relation(fields: [pet_id], references: [id], onDelete: Cascade)

  // audit M9: one like per user per generation — stops duplicate-like count
  // inflation and the repeated NFT-mint trigger.
  @@unique([user_id, generation_id])
  @@index([generation_id])
  @@map("likes")
}

model Comment {
  id            Int        @id @default(autoincrement())
  user_id       Int
  generation_id Int
  pet_id        Int?
  content       String     @db.Text
  parent_id     Int?
  is_deleted    Boolean    @default(false)
  created_at    DateTime   @default(now())
  updated_at    DateTime   @default(now()) @updatedAt
  user          User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  generation    Generation @relation(fields: [generation_id], references: [id], onDelete: Cascade)
  pet           Pet?       @relation(fields: [pet_id], references: [id], onDelete: Cascade)
  parent        Comment?   @relation("CommentReplies", fields: [parent_id], references: [id], onDelete: Cascade)
  replies       Comment[]  @relation("CommentReplies")

  @@map("comments")
}

model PetAgentReaction {
  id            Int        @id @default(autoincrement())
  pet_id        Int
  generation_id Int
  reacted       Boolean    @default(false)
  liked         Boolean    @default(false)
  commented     Boolean    @default(false)
  created_at    DateTime   @default(now())
  pet           Pet        @relation(fields: [pet_id], references: [id], onDelete: Cascade)
  generation    Generation @relation(fields: [generation_id], references: [id], onDelete: Cascade)

  @@unique([pet_id, generation_id])
  @@map("pet_agent_reactions")
}

model Follow {
  id           Int      @id @default(autoincrement())
  follower_id  Int
  following_id Int
  created_at   DateTime @default(now())
  follower     User     @relation("follower", fields: [follower_id], references: [id], onDelete: Cascade)
  following    User     @relation("following", fields: [following_id], references: [id], onDelete: Cascade)

  @@unique([follower_id, following_id], name: "uq_follower_following")
  @@map("follows")
}

// ── Phase 3: Evolution & Marketplace ──

model PetSkill {
  id          Int      @id @default(autoincrement())
  pet_id      Int
  skill_key   String   @db.VarChar(30)
  level       Int      @default(1)
  slot        Int? // 0-3: equipped slot, null = learned but not equipped
  unlocked_at DateTime @default(now())
  pet         Pet      @relation(fields: [pet_id], references: [id], onDelete: Cascade)

  @@unique([pet_id, skill_key])
  @@index([pet_id, slot])
  @@map("pet_skills")
}

model BattleHistory {
  id              Int      @id @default(autoincrement())
  player_pet_id   Int
  opponent_pet_id Int?
  opponent_name   String   @db.VarChar(50)
  won             Boolean
  turns           Int
  player_hp_left  Int      @default(0)
  exp_gained      Int      @default(0)
  points_earned   Int      @default(0)
  skill_drop_key  String?  @db.VarChar(30)
  tx_hash         String?  @db.VarChar(66)
  battle_type     String   @default("pvp") @db.VarChar(20)
  stage_id        Int?
  created_at      DateTime @default(now())
  // Replay fields — set at battle creation time, immutable thereafter.
  // battle_log: [{ turn, actor, dmg, their_hp, your_hp, crit?, miss? }, ...]
  // snapshot stats so a later stat upgrade doesn't make the replay misleading.
  battle_log      Json?
  seed            String?  @db.VarChar(66)
  player_hp_max   Int      @default(0)
  opponent_hp_max Int      @default(0)
  player_avatar   String?  @db.Text
  opponent_avatar String?  @db.Text

  @@index([player_pet_id])
  @@map("battle_history")
}

model PlaySession {
  id         Int      @id @default(autoincrement())
  user_id    Int
  date       DateTime @db.Date
  minutes    Int      @default(0)
  rewarded   Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@unique([user_id, date])
  @@map("play_sessions")
}

model PveProgress {
  id           Int       @id @default(autoincrement())
  user_id      Int
  pet_id       Int
  stage_id     Int       @default(1)
  stars        Int       @default(0)
  best_turns   Int?
  best_hp_left Int?
  cleared_at   DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @default(now()) @updatedAt

  @@unique([user_id, pet_id, stage_id])
  @@index([user_id])
  @@map("pve_progress")
}

model DailyTrainingLog {
  id            Int      @id @default(autoincrement())
  user_id       Int
  pet_id        Int
  date          DateTime @db.Date
  battles       Int      @default(0)
  exp_earned    Int      @default(0)
  credits_spent Int      @default(0)
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now()) @updatedAt

  @@unique([user_id, pet_id, date])
  @@map("daily_training_logs")
}

model ShopItem {
  id          Int               @id @default(autoincrement())
  key         String            @unique @db.VarChar(40)
  name        String            @db.VarChar(60)
  description String            @db.Text
  category    String            @db.VarChar(20)
  rarity      String            @default("common") @db.VarChar(15)
  price       Int
  icon        String            @db.VarChar(10)
  stat_bonus  Json?
  is_active   Boolean           @default(true)
  created_at  DateTime          @default(now())
  purchases   ItemPurchase[]
  equipped    PetEquippedItem[]

  @@map("shop_items")
}

model ItemPurchase {
  id         Int      @id @default(autoincrement())
  user_id    Int
  item_id    Int
  quantity   Int      @default(1)
  total_cost Int
  created_at DateTime @default(now())
  item       ShopItem @relation(fields: [item_id], references: [id])

  @@map("item_purchases")
}

model PetEquippedItem {
  id          Int      @id @default(autoincrement())
  pet_id      Int
  item_id     Int
  slot        String   @db.VarChar(20)
  equipped_at DateTime @default(now())
  pet         Pet      @relation(fields: [pet_id], references: [id], onDelete: Cascade)
  item        ShopItem @relation(fields: [item_id], references: [id])

  @@unique([pet_id, slot])
  @@map("pet_equipped_items")
}

model RewardRedemption {
  id            Int      @id @default(autoincrement())
  user_id       Int
  reward_id     Int
  reward_name   String   @db.VarChar(60)
  points_spent  Int
  status        String   @default("pending") @db.VarChar(20)
  delivery_note String?  @db.Text
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now()) @updatedAt

  @@index([user_id])
  @@map("reward_redemptions")
}

model UserProfile {
  id           Int      @id @default(autoincrement())
  user_id      Int      @unique
  display_name String?  @db.VarChar(50)
  bio          String?  @db.Text
  avatar_url   String?  @db.Text
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now()) @updatedAt
  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

// ── Phase 4: AI Pet Agent System ──

model PetPlatformConnection {
  id               Int       @id @default(autoincrement())
  pet_id           Int
  platform         String    @db.VarChar(20)
  is_active        Boolean   @default(true)
  credentials      String?   @db.Text
  config           Json?     @default("{}")
  platform_chat_id String?   @db.VarChar(100)
  webhook_secret   String?   @db.VarChar(64)
  connect_code     String?   @db.VarChar(10)
  connected_at     DateTime  @default(now())
  last_active_at   DateTime?
  pet              Pet       @relation(fields: [pet_id], references: [id], onDelete: Cascade)

  @@unique([pet_id, platform])
  @@index([connect_code])
  @@map("pet_platform_connections")
}

model PetAgentMessage {
  id              Int      @id @default(autoincrement())
  pet_id          Int
  platform        String   @db.VarChar(20)
  direction       String   @db.VarChar(10)
  message_type    String   @default("text") @db.VarChar(20)
  content         String   @db.Text
  platform_msg_id String?  @db.VarChar(100)
  chat_id         String?  @db.VarChar(100)
  credits_used    Int      @default(0)
  metadata        Json?
  created_at      DateTime @default(now())
  pet             Pet      @relation(fields: [pet_id], references: [id], onDelete: Cascade)

  @@index([pet_id, platform])
  @@index([chat_id])
  @@map("pet_agent_messages")
}

model PetAgentSchedule {
  id                      Int       @id @default(autoincrement())
  pet_id                  Int       @unique
  is_enabled              Boolean   @default(false)
  daily_credit_limit      Int       @default(50)
  credits_used_today      Int       @default(0)
  last_reset_at           DateTime  @default(now())
  posting_frequency       String    @default("medium") @db.VarChar(20)
  action_cooldown_minutes Int       @default(30)
  preferred_platform      String    @default("web") @db.VarChar(20)
  quiet_hours_start       Int?
  quiet_hours_end         Int?
  last_action_at          DateTime?
  pet                     Pet       @relation(fields: [pet_id], references: [id], onDelete: Cascade)

  @@map("pet_agent_schedules")
}

model PetConversation {
  id               Int       @id @default(autoincrement())
  pet_id           Int
  platform         String    @db.VarChar(20)
  chat_id          String    @db.VarChar(100)
  participant_name String?   @db.VarChar(100)
  summary          String?   @db.Text
  message_count    Int       @default(0)
  last_message_at  DateTime?
  created_at       DateTime  @default(now())
  pet              Pet       @relation(fields: [pet_id], references: [id], onDelete: Cascade)

  @@unique([pet_id, platform, chat_id])
  @@index([pet_id])
  @@map("pet_conversations")
}

// ── Phase 5: Pet Persona System ──

model PetPersona {
  id                 Int       @id @default(autoincrement())
  pet_id             Int       @unique
  // Onboarding answers
  owner_speech_style String?   @db.Text
  owner_interests    String?   @db.Text
  owner_expressions  String?   @db.Text
  owner_tone         String?   @db.VarChar(50)
  owner_language     String?   @db.VarChar(20)
  owner_bio          String?   @db.Text
  // Chat analysis results
  analyzed_patterns  Json?
  sample_messages    Json?
  vocabulary_style   String?   @db.Text
  // Connected agent observations
  observed_topics    Json?
  observed_style     Json?
  last_observed_at   DateTime?
  // Meta
  persona_version    Int       @default(1)
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  pet                Pet       @relation(fields: [pet_id], references: [id], onDelete: Cascade)

  @@map("pet_personas")
}

// ── Phase 6: Web4.0 Sovereignty (Soulbound NFT) ──

model PetSoulNft {
  id                Int                 @id @default(autoincrement())
  pet_id            Int                 @unique
  token_id          Int?
  owner_wallet      String              @db.VarChar(42)
  genesis_hash      String              @db.VarChar(66)
  current_hash      String              @db.VarChar(66)
  current_version   Int                 @default(1)
  mint_tx_hash      String?             @db.VarChar(66)
  mint_block        Int?
  chain             String              @default("bsc") @db.VarChar(10)
  minted_at         DateTime?
  last_heartbeat_at DateTime?
  successor_wallet  String?             @db.VarChar(42)
  is_deceased       Boolean             @default(false)
  inherited_from    String?             @db.VarChar(42)
  created_at        DateTime            @default(now())
  updated_at        DateTime            @updatedAt
  pet               Pet                 @relation(fields: [pet_id], references: [id], onDelete: Cascade)
  checkpoints       PersonaCheckpoint[]

  @@index([owner_wallet])
  @@index([token_id])
  @@map("pet_soul_nfts")
}

model PersonaCheckpoint {
  id               Int        @id @default(autoincrement())
  soul_id          Int
  pet_id           Int
  version          Int
  persona_hash     String     @db.VarChar(66)
  persona_snapshot Json
  trigger_event    String     @db.VarChar(50)
  tx_hash          String?    @db.VarChar(66)
  block_number     Int?
  on_chain         Boolean    @default(false)
  created_at       DateTime   @default(now())
  soul             PetSoulNft @relation(fields: [soul_id], references: [id], onDelete: Cascade)

  @@index([pet_id, version])
  @@index([soul_id])
  @@map("persona_checkpoints")
}

model MemoryNft {
  id              Int       @id @default(autoincrement())
  pet_id          Int
  memory_id       Int?
  soul_token_id   Int?
  memory_token_id Int?
  content_hash    String    @unique @db.VarChar(66)
  memory_type     Int
  importance      Int       @default(1)
  title           String?   @db.VarChar(200)
  description     String?   @db.Text
  ipfs_cid        String?   @db.VarChar(128)
  mint_tx_hash    String?   @db.VarChar(66)
  chain           String    @default("bsc") @db.VarChar(10)
  owner_wallet    String    @db.VarChar(42)
  minted_at       DateTime?
  created_at      DateTime  @default(now())
  pet             Pet       @relation(fields: [pet_id], references: [id], onDelete: Cascade)

  @@index([pet_id])
  @@index([owner_wallet])
  @@map("memory_nfts")
}

model InheritanceEvent {
  id            Int      @id @default(autoincrement())
  pet_id        Int
  from_wallet   String   @db.VarChar(42)
  to_wallet     String   @db.VarChar(42)
  reason        String   @db.VarChar(50)
  inactive_days Int?
  tx_hash       String?  @db.VarChar(66)
  claimed_at    DateTime @default(now())
  pet           Pet      @relation(fields: [pet_id], references: [id], onDelete: Cascade)

  @@index([pet_id])
  @@map("inheritance_events")
}

// ── Unified payment receipts for every paid action ──
// Pattern: client signs USDT transfer to Treasury → posts tx_hash here.
// Server verifies on-chain (already done in /api/credits/purchase) and records.
// `action_key` keys: feed_extra, play_extra, stat_upgrade_atk, stat_upgrade_def,
// stat_upgrade_spd, battle_entry, skill_install, generation_extra, etc.
// `replay_key` is unique so two requests can't claim the same tx_hash.
model PaidAction {
  id          Int       @id @default(autoincrement())
  user_id     Int
  pet_id      Int?
  action_key  String    @db.VarChar(40)
  amount_usd  Float
  tx_hash     String    @unique @db.VarChar(66)
  burn_amount Float     @default(0) // 50% of amount_usd; settled async by burn cron
  burned_tx   String?   @db.VarChar(66)
  consumed_at DateTime? // set when the gated action actually executes; null = available
  metadata    Json?     @default("{}")
  created_at  DateTime  @default(now())

  @@index([user_id])
  @@index([action_key])
  @@index([created_at])
  @@map("paid_actions")
}

// ── Weekly Battle Pool snapshots ──
// Every Sunday 00:00 UTC the cron at /api/cron/distribute-pool closes the
// current week, captures top-100 by power, and records payouts. Actual USDT
// transfer happens manually (or via funded relayer) using the rows here.
model WeeklyBattlePool {
  id            Int       @id @default(autoincrement())
  week_key      String    @unique @db.VarChar(10) // "2026-W21"
  closed_at     DateTime  @default(now())
  pool_usd      Float // 70% of entry fees this week
  total_entries Int       @default(0)
  // payouts: [{ rank, petId, walletAddress, payoutUsd, paidTx? }, ...]
  payouts       Json      @default("[]")
  paid_out      Boolean   @default(false)
  paid_at       DateTime?

  @@map("weekly_battle_pools")
}

// ── Studio subscription (Phase 2) ──
// One row per user. Created on first signup at "free" tier. Upgraded via
// /api/studio/subscription with a USDT tx_hash (BSC). expires_at advances
// by 30 days per payment. Downgrade to free if expires_at < now.
model UserSubscription {
  id              Int       @id @default(autoincrement())
  user_id         Int       @unique
  tier            String    @default("free") @db.VarChar(10) // "free" | "pro" | "studio"
  started_at      DateTime  @default(now())
  expires_at      DateTime?
  last_payment_tx String?   @unique @db.VarChar(66)
  total_paid_usd  Float     @default(0)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @default(now()) @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_subscriptions")
}

// Monthly Studio usage counters — videos + images generated this month.
// Enforced by /api/studio/generate. month_key = "YYYY-MM" UTC.
model StudioMonthlyUsage {
  id          Int      @id @default(autoincrement())
  user_id     Int
  month_key   String   @db.VarChar(7)
  videos_used Int      @default(0)
  images_used Int      @default(0)
  updated_at  DateTime @default(now()) @updatedAt

  @@unique([user_id, month_key], name: "user_month")
  @@map("studio_monthly_usage")
}

// ── Daily free-tier counters (replaces in-memory rate-limit for paid features) ──
// Resets at UTC midnight. Lookup is O(1) via composite unique.
model DailyActionCount {
  id         Int      @id @default(autoincrement())
  user_id    Int
  action_key String   @db.VarChar(40)
  day        String   @db.VarChar(10) // "2026-05-22"
  count      Int      @default(0)
  updated_at DateTime @default(now()) @updatedAt

  @@unique([user_id, action_key, day], name: "user_action_day")
  @@index([day])
  @@map("daily_action_counts")
}

// ───────────────────────────────────────────────────────────────────────────
// MISSION SYSTEM (Phase 1 — daily missions + mission-streak)
// ───────────────────────────────────────────────────────────────────────────
// daily_missions:    one row per (user, date, mission). Status flips to
//                    "completed" when verified. Points are stamped at assign
//                    time so we never retroactively rebalance.
// user_streaks:      single source of truth for mission-streak state. The
//                    legacy `petInteraction.checkin` streak still exists for
//                    the old card — mission-streak supersedes it for the new
//                    leaderboard.
// streak_purchases:  audit trail for shield + repair purchases (cash or
//                    credits or $PET in future).

model DailyMission {
  id           Int       @id @default(autoincrement())
  user_id      Int
  date         String    @db.VarChar(10)   // "YYYY-MM-DD" UTC
  mission_id   String    @db.VarChar(60)   // matches mission catalog key
  category     String    @db.VarChar(20)
  title        String    @db.VarChar(120)
  points       Int
  status       String    @default("pending") @db.VarChar(20) // pending | completed
  completed_at DateTime?
  bonus_x     Float     @default(1.0)    // hourly-drop multiplier captured at completion
  created_at   DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, date, mission_id], name: "user_date_mission")
  @@index([user_id, date])
  @@index([date])
  @@map("daily_missions")
}

model UserStreak {
  user_id              Int       @id
  current_streak       Int       @default(0)
  longest_streak       Int       @default(0)
  last_completed_date  String?   @db.VarChar(10)    // last YYYY-MM-DD with >=1 completion
  shields_owned        Int       @default(0)
  shields_used         Int       @default(0)
  last_shield_used_at  DateTime?
  total_missions_done  Int       @default(0)
  total_points_earned  Int       @default(0)
  // For pet emotional memory — set when a miss is detected so the pet can
  // open the next conversation with "Where were you yesterday?"
  pending_apology      Boolean   @default(false)
  pending_apology_days Int       @default(0)
  updated_at           DateTime  @default(now()) @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_streaks")
}

model StreakPurchase {
  id               Int      @id @default(autoincrement())
  user_id          Int
  kind             String   @db.VarChar(30)  // shield | repair-1d | repair-7d | ... | doubler | week_1_5x | bundle
  price_usd        Float                     // sticker price at purchase
  paid_via         String   @db.VarChar(20)  // credits | usdt | pet_token
  paid_credits     Int?                      // amount of in-app credits debited
  tx_hash          String?  @db.VarChar(66)
  streak_before    Int
  streak_after     Int
  created_at       DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, created_at])
  @@map("streak_purchases")
}

// ───────────────────────────────────────────────────────────────────────────
// MISSION SYSTEM — Phase 2 + 3
// ───────────────────────────────────────────────────────────────────────────
// hourly_drops:        a single global drop per hour (everyone sees the same).
// periodic_missions:   weekly + monthly missions (period: "week" | "month").
// streak_buddies:      one row per pair. Shared streak = min(both streaks).
// streak_sos:          requests for help when a streak is about to break.
// pet_dates:           AI-generated chat log between two pets.
// user_subscriptions:  premium tier (free / pro / studio).

model HourlyDrop {
  id           Int      @id @default(autoincrement())
  kind         String   @db.VarChar(30)  // snack | memory | studio | compliment | chat | care
  label        String   @db.VarChar(80)
  emoji        String   @db.VarChar(8)
  multiplier_x Float    @default(2.0)
  applies_to   String   @db.VarChar(20)  // mission category boosted (or "*" for all)
  starts_at    DateTime
  ends_at      DateTime
  created_at   DateTime @default(now())
  @@index([starts_at, ends_at])
  @@map("hourly_drops")
}

model PeriodicMission {
  id           Int       @id @default(autoincrement())
  user_id      Int
  period       String    @db.VarChar(8)   // "week" | "month"
  period_key   String    @db.VarChar(10)  // "2026-W24" or "2026-06"
  mission_id   String    @db.VarChar(60)
  category     String    @db.VarChar(20)
  title        String    @db.VarChar(160)
  target       Int                          // e.g. "5 generations"
  progress     Int       @default(0)
  points       Int
  status       String    @default("pending") @db.VarChar(20)
  completed_at DateTime?
  created_at   DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, period, period_key, mission_id], name: "user_period_mission")
  @@index([user_id, period_key])
  @@map("periodic_missions")
}

model StreakBuddy {
  id            Int      @id @default(autoincrement())
  user_a_id     Int      // initiator
  user_b_id     Int      // accepter
  status        String   @default("pending") @db.VarChar(12) // pending | active | ended
  shared_streak Int      @default(0)
  last_active_a String?  @db.VarChar(10)
  last_active_b String?  @db.VarChar(10)
  created_at    DateTime @default(now())
  accepted_at   DateTime?
  ended_at      DateTime?

  user_a User @relation("StreakBuddyA", fields: [user_a_id], references: [id], onDelete: Cascade)
  user_b User @relation("StreakBuddyB", fields: [user_b_id], references: [id], onDelete: Cascade)

  @@unique([user_a_id, user_b_id], name: "buddy_pair")
  @@index([user_a_id])
  @@index([user_b_id])
  @@map("streak_buddies")
}

model StreakSos {
  id            Int       @id @default(autoincrement())
  sender_id     Int
  sender_streak Int                       // streak we're trying to save
  expires_at    DateTime                  // when the gap will become permanent
  helped_by_id  Int?                      // null until someone helps
  helped_at     DateTime?
  credits_paid  Int       @default(0)
  message       String?   @db.VarChar(280)
  created_at    DateTime  @default(now())

  sender User @relation("SosSender", fields: [sender_id], references: [id], onDelete: Cascade)
  helper User? @relation("SosHelper", fields: [helped_by_id], references: [id])

  @@index([expires_at])
  @@index([sender_id, created_at])
  @@map("streak_sos")
}

model PetDate {
  id           Int      @id @default(autoincrement())
  pet_a_id     Int
  pet_b_id     Int
  initiator_id Int                          // user who started it
  log          String   @db.Text             // JSON: [{speaker: "A"|"B", text: "..."}]
  vibe         String   @db.VarChar(40)      // "playful" | "deep" | "rivalry" | "shy"
  friendship   Int      @default(0)          // -100..100
  created_at   DateTime @default(now())

  initiator User @relation(fields: [initiator_id], references: [id], onDelete: Cascade)

  @@index([pet_a_id])
  @@index([pet_b_id])
  @@index([initiator_id, created_at])
  @@map("pet_dates")
}
