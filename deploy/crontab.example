# PetClaw production cron — install on the EC2 instance with:
#   crontab -e
# then paste these lines (replace $CRON_SECRET with the value from .env).
#
# Memory consolidation: every hour, processes pets active in last 7 days.
# Skips pets that haven't had 20+ new turns since last run (cheap no-ops).
0 * * * * /usr/bin/curl -fsS -X POST "https://app.myaipet.ai/api/petclaw/memory/consolidate?cron=1" -H "x-cron-secret: $CRON_SECRET" >> /var/log/petclaw-consolidate.log 2>&1

# Optional: nightly memory anchor checkpoint for pets with souls. Only meaningful
# after BLOCKCHAIN_ENABLED=true + relayer is funded.
# 30 3 * * * /usr/bin/curl -fsS -X POST "https://app.myaipet.ai/api/petclaw/memory/anchor-batch?cron=1" -H "x-cron-secret: $CRON_SECRET" >> /var/log/petclaw-anchor.log 2>&1
