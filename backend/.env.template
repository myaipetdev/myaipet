# ═══════════════════════════════════════════
#  PETAGEN Backend Environment
#  Copy to .env and fill in values
# ═══════════════════════════════════════════

# ── Database ──
DATABASE_URL=sqlite+aiosqlite:///./petagen.db

# ── JWT ──
JWT_SECRET=change-me-to-a-random-32-char-string
JWT_EXPIRE_MINUTES=1440

# ── Blockchain - RPC ──
RPC_BASE=https://mainnet.base.org
RPC_BNB=https://bsc-dataseed.binance.org/

# ── Blockchain - Contracts ──
CONTRACT_BASE=0x_YOUR_BASE_CONTRACT_HERE
CONTRACT_BNB=0x_YOUR_BNB_CONTRACT_HERE

# ── Blockchain - Backend Relayer (separate from simulator!) ──
# Fund with ~0.01 ETH on Base + ~0.05 BNB on BNB Chain
BACKEND_RELAYER_KEY=0x_YOUR_BACKEND_RELAYER_PRIVATE_KEY

# ── Simulator Relayer (keep original for simulator.py) ──
RELAYER_KEY=0x_YOUR_SIMULATOR_RELAYER_PRIVATE_KEY

# ── AI Video Generation (fal.ai) ──
FAL_API_KEY=your-fal-ai-api-key
DEFAULT_VIDEO_TIER=premium  # budget|standard|premium|ultra
# budget:   Hailuo 02 Fast    (~$0.10/5s, 768p)
# standard: Hailuo 02 Std     (~$0.23/5s, 768p)
# premium:  Kling 3.0 Std     (~$0.42/5s, 1080p)
# ultra:    Kling 3.0 Pro      (~$0.56/5s, 1080p)

# ── Grok API (x.ai) ──
GROK_API_KEY=your-grok-api-key

# ── X402 Payment Protocol ──
X402_WALLET_ADDRESS=0x_YOUR_USDC_WALLET_ON_BASE
X402_INTERNAL_KEY=change-me-random-secret
CDP_API_KEY=your-coinbase-cdp-key

# ── IPFS / Pinata (for SOUL.md exports) ──
PINATA_JWT=your-pinata-jwt

# ── File Storage ──
UPLOAD_DIR=./uploads
VIDEO_DIR=./videos
MAX_UPLOAD_SIZE_MB=10

# ── Server ──
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,https://your-domain.com
